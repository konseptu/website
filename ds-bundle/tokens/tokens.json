{
  "$meta": {
    "name": "Konseptu brand tokens",
    "source": "konseptu.com website repo",
    "defaultMode": "dark",
    "note": "Site ships dark-mode-first (config ui.theme = 'dark:only')."
  },
  "color": {
    "primary":        { "light": "#411ce6", "dark": "#481fff", "var": "--aw-color-primary" },
    "primary-light":  { "light": "#7152fd", "dark": "#7152fd", "var": "--aw-color-primary-light" },
    "secondary":      { "light": "#00bf77", "dark": "#00ff9f", "var": "--aw-color-secondary" },
    "secondary-light":{ "light": "#68fcc5", "dark": "#68fcc5", "var": "--aw-color-secondary-light" },
    "accent":         { "light": "#e66100", "dark": "#ff4f00", "var": "--aw-color-accent" },
    "text-heading":   { "light": "rgb(0 0 0)", "dark": "rgb(247 248 248)", "var": "--aw-color-text-heading" },
    "text-default":   { "light": "rgb(16 16 16)", "dark": "rgb(229 236 246)", "var": "--aw-color-text-default" },
    "text-muted":     { "light": "rgb(16 16 16 / 66%)", "dark": "rgb(229 236 246 / 66%)", "var": "--aw-color-text-muted" },
    "bg-page":        { "light": "rgb(255 255 255)", "dark": "rgb(3 6 32)", "var": "--aw-color-bg-page" }
  },
  "font": {
    "sans":    { "value": "Inter Variable", "var": "--aw-font-sans" },
    "serif":   { "value": "Inter Variable", "var": "--aw-font-serif" },
    "heading": { "value": "Inter Variable", "var": "--aw-font-heading" },
    "mono":    { "value": "Roboto Mono", "var": "--aw-font-mono" }
  },
  "radius": {
    "button": { "value": "9999px", "note": "Buttons are fully pill-shaped." }
  }
}
