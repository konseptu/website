---
import Layout from '~/layouts/PageLayout.astro';
import Content from '~/components/widgets/Content.astro';
import Features from '~/components/widgets/Features.astro';
import enterpriseApp from '~/assets/images/enterprise-app-square-hero.png';
import erp from '~/assets/images/erp.png';
import hrm from '~/assets/images/hrm.png';
import cms from '~/assets/images/cms.png';
import timeTracker from '~/assets/images/time-tracker.png';
import dms from '~/assets/images/dms.png';
import Hero2 from '~/components/widgets/Hero2.astro';

const metadata = {
  title: 'studio · Custom Software',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget -->
  <Hero2
    image={{ src: enterpriseApp, alt: 'studio · Custom Software Development' }}
    tagline="Custom Software Development"
    subtitle="Bespoke software, tailored to how your team actually works. We get the core live fast, then grow it module by module, mixing pre-made building blocks with custom work so you get exactly what you need without the off-the-shelf baggage."
  >
    <Fragment slot="title"><span class="wordmark">studio</span></Fragment>
  </Hero2>

  <!-- HRM Section -->
  <Content
    isReversed
    image={{ src: hrm, alt: 'Human Resource Management' }}
    title="Human Resource Management"
    items={[
      {
        title: 'Streamlined HR Processes',
        description: 'Automate core HR functions, from recruitment to payroll and performance management.',
      },
      {
        title: 'Employee Data Management',
        description: 'Maintain accurate and up-to-date records, ensuring compliance and smooth HR operations.',
      },
      {
        title: 'Employee Engagement',
        description: 'Enhance employee satisfaction with tools for performance tracking, feedback, and development.',
      },
      {
        title: 'Scalable & Customizable',
        description: "Adapt the system to your company's specific needs and grow with your business.",
      },
    ]}
  >
    <Fragment slot="subtitle">
      Transform your HR operations with our comprehensive human resource management system.
    </Fragment>
  </Content>

  <!-- CMS Section -->
  <Content
    title="Content Management System"
    image={{ src: cms, alt: 'Content Management System' }}
    items={[
      {
        title: 'Centralized Content Creation',
        description: 'Easily manage and publish content across multiple platforms with a unified system.',
      },
      {
        title: 'Collaboration Tools',
        description: 'Empower teams to work together on content creation, review, and approval in real time.',
      },
      {
        title: 'SEO & Analytics',
        description:
          'Built-in tools for optimizing content and tracking performance to improve visibility and engagement.',
      },
      {
        title: 'Scalable Solutions',
        description: 'Whether you have a small website or enterprise-level platform, our CMS grows with you.',
      },
    ]}
  >
    <Fragment slot="subtitle"> Manage your content efficiently with our powerful CMS solution. </Fragment>
  </Content>

  <!-- Time Tracking Section -->
  <Content
    isReversed
    title="Time Tracking System"
    image={{ src: timeTracker, alt: 'Time Tracking System' }}
    items={[
      {
        title: 'Efficient Time Management',
        description:
          'Track employee hours, project times, and attendance effortlessly, improving accuracy in payroll and project management.',
      },
      {
        title: 'Real-Time Reporting',
        description: 'Monitor time usage and generate reports to identify inefficiencies and improve productivity.',
      },
      {
        title: 'Integrates with Payroll',
        description: 'Seamlessly integrate time data with payroll systems to reduce manual errors.',
      },
      {
        title: 'User-Friendly Interface',
        description: 'Simple, intuitive design for both employees and managers to track time effectively.',
      },
    ]}
  >
    <Fragment slot="subtitle">
      Track and manage time efficiently with our comprehensive time tracking solution.
    </Fragment>
  </Content>

  <!-- ERP Section -->
  <Content
    title="Enterprise Resource Planning"
    image={{ src: erp, alt: 'ERP System' }}
    items={[
      {
        title: 'Unified Business Processes',
        description: 'Integrate finance, HR, supply chain, and other key business functions into one cohesive system.',
      },
      {
        title: 'Real-Time Data Access',
        description: 'Make informed decisions with access to real-time data and comprehensive analytics.',
      },
      {
        title: 'Streamlined Operations',
        description: 'Reduce redundancies and improve efficiency by automating workflows across departments.',
      },
      {
        title: 'Customizable & Scalable',
        description: 'Tailor the ERP system to fit your unique business needs and scale it as you grow.',
      },
    ]}
  >
    <Fragment slot="subtitle"> Unify your business processes with our comprehensive ERP solution. </Fragment>
  </Content>

  <!-- DMS Section -->
  <Content
    isReversed
    title="Document Management System"
    image={{ src: dms, alt: 'Document Management System' }}
    items={[
      {
        title: 'Secure Document Storage',
        description: 'Safely store and organize documents with encrypted access and strict security controls.',
      },
      {
        title: 'Easy Retrieval & Sharing',
        description: 'Quickly find and share documents with your team, enhancing collaboration and productivity.',
      },
      {
        title: 'Compliance & Audit Trails',
        description: 'Maintain compliance with industry standards by tracking document versions and access logs.',
      },
      {
        title: 'Automated Workflow',
        description: 'Automate document approval processes and enhance operational efficiency.',
      },
    ]}
  >
    <Fragment slot="subtitle"> Manage your documents securely and efficiently with our DMS solution. </Fragment>
  </Content>

  <!-- Features Section -->
  <Features
    title="How We Do It"
    items={[
      {
        title: 'Develop From Scratch',
        description: 'We build custom solutions tailored to your specific business needs from the ground up.',
      },
      {
        title: 'Take Existing Project',
        description: 'We enhance and integrate with your existing systems to improve functionality and performance.',
      },
      {
        title: 'Off the Shelf',
        description:
          'We provide ready-made solutions that can be quickly implemented to meet your business requirements.',
      },
    ]}
  >
    <Fragment slot="subtitle"> Discover the three ways we deliver solutions to meet your business needs. </Fragment>
  </Features>

  <!-- Why Choose Us -->
  <Features
    title="Why Choose Us?"
    items={[
      {
        title: 'Core first',
        description: 'We get your essential workflow live fast, then expand module by module, so you see value sooner.',
        icon: 'tabler:rocket',
      },
      {
        title: 'Built around you',
        description: 'Customized as close as possible to how your team actually works, not the other way around.',
        icon: 'tabler:settings',
      },
      {
        title: 'Software and hardware, one team',
        description: 'The same people who build your software can spec and set up the infrastructure it runs on.',
        icon: 'tabler:package',
      },
      {
        title: 'Yours to grow',
        description: 'As your operation changes, the software changes with it. No rip-and-replace down the line.',
        icon: 'tabler:trending-up',
      },
    ]}
  >
    <Fragment slot="subtitle"> Reasons teams pick Studio for software built around their workflow. </Fragment>
  </Features>
</Layout>
