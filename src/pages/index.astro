---
import Layout from '~/layouts/PageLayout.astro';

import LivelyHero from '~/components/widgets/LivelyHero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import InfrastructureProducts from '~/components/widgets/InfrastructureProducts.astro';
import OurClients from '~/components/widgets/OurClients.astro';
// import aiAssist from '~/assets/images/ai-assist.svg';
import queueSys from '~/assets/images/queuing-square-hero.png';
import userFeedback from '~/assets/images/user-feedback-square-hero.png';
import enterpriseApp from '~/assets/images/enterprise-app-square-hero.png';
import enterpriseHero from '~/assets/images/enterprise-app-long-hero.png';

// Infrastructure product logos
import ibmLogo from '~/assets/product-logos/ibm.png';
import lenovoLogo from '~/assets/product-logos/lenovo.png';
import dellLogo from '~/assets/product-logos/dell.png';
import hpeLogo from '~/assets/product-logos/hpe.png';
import acerLogo from '~/assets/product-logos/acer.png';
import intelLogo from '~/assets/product-logos/intel.png';
import microsoftLogo from '~/assets/product-logos/microsoft.png';
import awsLogo from '~/assets/product-logos/aws.png';
import peplinkLogo from '~/assets/product-logos/peplink.gif';
import ruijieLogo from '~/assets/product-logos/ruijie.svg';
import ciscoLogo from '~/assets/product-logos/cisco.png';
import ubiquitiLogo from '~/assets/product-logos/ubiquiti.png';
import hikvisionLogo from '~/assets/product-logos/hikvision.png';
import dahuaLogo from '~/assets/product-logos/dahua.png';
import zktecoLogo from '~/assets/product-logos/zkteco.png';
import apcLogo from '~/assets/product-logos/apc.png';
import cyberpowerLogo from '~/assets/product-logos/cyberpower.png';
import vertivLogo from '~/assets/product-logos/vertiv.png';
import epsonLogo from '~/assets/product-logos/epson.png';
import eloLogo from '~/assets/product-logos/elo.png';
import sangforLogo from '~/assets/product-logos/sangfor.avif';

// Client logos
import ipiClientLogo from '~/assets/client-logos/ipi.png';
import clinicaPrimeLogo from '~/assets/client-logos/clinicaprime.png';
import tallecoLogo from '~/assets/client-logos/talleco.png';
import inaMicroLogo from '~/assets/client-logos/inamicro.png';
import seihaLogo from '~/assets/client-logos/seiha.png';
import iloiloMissionLogo from '~/assets/client-logos/iloilo-mission-hospital.png';
import dotLogo from '~/assets/client-logos/department-of-tourism.svg';

const metadata = {
  title: 'Custom Software, IT Infrastructure & Queue Systems in Cebu | Konseptu',
  description:
    'Konseptu is a Cebu-based IT consultancy building custom software, queue management (turno) and customer feedback (revue) systems, plus complete IT infrastructure and hardware for businesses across the Visayas and the Philippines.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <link slot="head" rel="preload" as="image" href={enterpriseHero.src} fetchpriority="high" />
  <!-- Hero Widget ******************* -->

  <LivelyHero
    tagline="Your trusted local IT partner"
    actions={[
      {
        variant: 'primary',
        text: 'Get Free Consultation',
        href: '#cta',
      },
    ]}
  >
    <Fragment slot="title">
      <span class="font-bold ocean-left-first-gradient-text">All-in-one</span>
      <span class="font-bold ocean-left-second-gradient-text">software</span>
      <span class="font-bold ocean-right-second-gradient-text">and infra</span>
      <span class="font-bold ocean-right-first-gradient-text">solutions</span>
    </Fragment>

    <Fragment slot="subtitle">
      From ready-made or custom applications to complete IT infrastructure, <span class="font-extrabold"
        >we deliver everything your business needs</span
      >.
    </Fragment>

    <Fragment slot="content">
      <button
        class="mt-8 flex w-full flex-col items-center text-md font-medium tracking-wider text-gray-600 hover:text-primary-600 dark:text-gray-400 dark:hover:text-primary-400 transition-colors"
        onclick="document.getElementById('product-1').scrollIntoView({behavior: 'smooth'})"
      >
        See our products
        <span class="mt-2.5">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="animate-bounce"
          >
            <path d="m7 15 5 5 5-5"></path>
            <path d="m7 7 5 5 5-5"></path>
          </svg>
        </span>
      </button>
    </Fragment>
  </LivelyHero>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    id="product-1"
    title="Our products"
    image={{
      src: enterpriseApp,
      alt: 'Enterprise App',
    }}
    items={[
      {
        title: 'Core first, so you go live sooner',
        description: 'We build the essential workflow first and get it running, then add the rest module by module.',
      },
      {
        title: 'Pre-made modules, none of the off-shelf baggage',
        description:
          'Start from proven building blocks, customized as close as you need to how your team actually works.',
      },
      {
        title: 'One team for software and hardware',
        description: 'The people who write your software can also spec and set up the infrastructure it runs on.',
      },
      {
        title: 'Yours to grow',
        description: 'As your operation changes, the software changes with it. No rip-and-replace down the line.',
      },
    ]}
  >
    <Fragment slot="subtitle">
      Ready-made products and fully custom software, from queue management and customer feedback to systems built from
      scratch, that digitize and streamline how you work.
    </Fragment>
    <Fragment slot="content">
      <h3 class="wordmark text-4xl sm:text-5xl dark:text-white mb-1">studio</h3>
      <p class="text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200 mb-3">
        Custom Software Development
      </p>
      Every business runs differently. Studio builds software shaped to how your team works, gets the core live fast, then
      grows from there, mixing pre-made modules with custom work so you get exactly what you need.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    image={{
      src: queueSys,
      alt: 'Queue System',
    }}
    items={[
      {
        title: 'Intuitive customer experience',
        description: 'Generate tickets on-site or remotely with easy-to-use interfaces',
      },
      {
        title: 'Performance at scale',
        description: 'Handle thousands of daily tickets with priority and standard queues',
      },
      {
        title: 'Real-time monitoring',
        description: 'Keep customers informed through display monitors and SMS updates',
      },
      {
        title: 'Efficient processing',
        description: 'Automatic categorization and data archiving for optimized operations',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="wordmark text-4xl sm:text-5xl dark:text-white mb-1">turno</h3>
      <p class="text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200 mb-3">
        Queue Management
      </p>
      Streamline your customer queuing with our proven solution, capable of handling thousands of tickets per day while maintaining
      exceptional customer satisfaction.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent
    image={{
      src: userFeedback,
      alt: 'User Feedback System',
    }}
    items={[
      {
        title: 'Build the form your way',
        description:
          'Smiley faces, thumbs, or nested tags. Shape it as simple or as detailed as you want, and change it anytime.',
      },
      {
        title: 'Feedback at the point of service',
        description:
          'Place it where customers are, or bring it over at bill-out, so you hear from everyone, not only the complainers.',
      },
      {
        title: 'Live dashboard',
        description:
          'Every response lands instantly, with ratings, trends, and reports you can filter and export, even when offline.',
      },
      {
        title: 'Make every rating specific',
        description:
          'When you want, staff can log what a customer actually received, so they rate their real order rather than a vague score.',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="wordmark text-4xl sm:text-5xl dark:text-white mb-1">revue</h3>
      <p class="text-sm font-semibold uppercase tracking-wide text-secondary dark:text-blue-200 mb-3">
        Customer Feedback
      </p>
      Understand your customers where it matters most. Revue captures how they really feel right at the point of service,
      in just a tap or two, with a form you shape yourself.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <!-- <Content
    isReversed
    isAfterContent
    image={{
      src: aiAssist,
      alt: 'Online Business Suite',
    }}
    items={[
      {
        title: 'Swift deployment',
        description: 'Get your website live in as little as 5 days',
      },
      {
        title: 'Complete digital package',
        description:
          'Includes hosting, Google Business Profile, Google Maps, SEO monitoring and boosting, and AI translation',
      },
      {
        title: 'Flexible options',
        description: 'Choose from pre-built templates or custom solutions with ongoing maintenance',
      },
      {
        title: 'Multilingual support',
        description: 'Reach broader, foreign audiences with AI-powered translation',
      },
    ]}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Online Business Expansion Suite
      </h3>
      Accelerate your online presence with rapid website development and comprehensive digital solutions.
      <div class="mt-6">
        <a
          href="/products/online-business"
          class="text-primary-600 hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300 font-semibold transition duration-150 ease-in-out"
        >
          See more →
        </a>
      </div>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content> -->

  <!-- Infrastructure Products Widget **************** -->

  <InfrastructureProducts
    title="Enterprise IT Infrastructure & Solutions"
    subtitle="We specialize in delivering high-performance IT infrastructure, security, and software solutions for businesses of all sizes."
    topTierBrands={[
      { name: 'IBM', logo: ibmLogo },
      { name: 'Lenovo', logo: lenovoLogo },
      { name: 'Dell', logo: dellLogo },
      { name: 'HPE', logo: hpeLogo },
      { name: 'Microsoft', logo: microsoftLogo },
      { name: 'Cisco', logo: ciscoLogo },
      { name: 'Hikvision', logo: hikvisionLogo },
    ]}
    categories={[
      {
        title: 'Computing Solutions',
        brands: [
          { name: 'IBM', logo: ibmLogo, description: 'Enterprise Servers, Storage & Software' },
          {
            name: 'Lenovo',
            logo: lenovoLogo,
            description: 'Business Laptops, Desktops, ThinkPad, ThinkCentre, ThinkSystem',
          },
          { name: 'Dell', logo: dellLogo, description: 'OptiPlex, PowerEdge Servers, Latitude Laptops' },
          { name: 'HPE', logo: hpeLogo, description: 'Servers, Storage, Networking' },
          { name: 'Acer', logo: acerLogo, description: 'Business Notebooks, Monitors & Projectors' },
          { name: 'Intel', logo: intelLogo, description: 'Processors, Server Components & Compute Modules' },
          { name: 'Microsoft', logo: microsoftLogo, description: 'Windows OS, Office Suite, Microsoft 365, Azure' },
          { name: 'AWS', logo: awsLogo, description: 'Cloud Solutions & Deployment' },
        ],
      },
      {
        title: 'Networking & Connectivity',
        brands: [
          { name: 'Ubiquiti', logo: ubiquitiLogo, description: 'UniFi Access Points, Routers, Network Management' },
          { name: 'Peplink', logo: peplinkLogo, description: 'SD-WAN, LTE Routers, VPN Solutions' },
          { name: 'Ruijie Networks', logo: ruijieLogo, description: 'Wi-Fi Solutions, Access Points, Switches' },
          { name: 'Cisco', logo: ciscoLogo, description: 'Enterprise Networking, Security, VoIP, Switches' },
          { name: 'Sangfor', logo: sangforLogo, description: 'Network Security, SD-WAN, Cloud Solutions' },
        ],
      },
      {
        title: 'Security & Surveillance',
        brands: [
          { name: 'Hikvision', logo: hikvisionLogo, description: 'CCTV, IP Cameras, NVRs, Access Control' },
          { name: 'Dahua', logo: dahuaLogo, description: 'Surveillance Systems, Smart Security Solutions' },
          { name: 'ZKTeco', logo: zktecoLogo, description: 'Biometric Access Control, Time Attendance' },
        ],
      },
      {
        title: 'Power Solutions',
        brands: [
          { name: 'APC UPS', logo: apcLogo, description: 'Uninterruptible Power Supply, Surge Protectors' },
          { name: 'CyberPower UPS', logo: cyberpowerLogo, description: 'Backup Power & Surge Protection' },
          { name: 'Vertiv', logo: vertivLogo, description: 'Power Management, Data Center Infrastructure' },
        ],
      },
      {
        title: 'Peripherals & Office Equipment',
        brands: [
          { name: 'Epson', logo: epsonLogo, description: 'Printers, Projectors, Scanners' },
          { name: 'Elo Touch Solutions', logo: eloLogo, description: 'Touchscreen Monitors & Displays' },
        ],
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </InfrastructureProducts>

  <!-- Our Clients Widget *********** -->

  <OurClients
    id="clients"
    title="Trusted by organizations across the Philippines"
    clients={[
      { name: 'IPI Philippines', logo: ipiClientLogo, width: 300, height: 185 },
      { name: 'Clinica Prime', logo: clinicaPrimeLogo, width: 300, height: 64 },
      { name: 'Talleco · JobTarget', logo: tallecoLogo, width: 300, height: 96 },
      { name: 'Ina Micro Opto', logo: inaMicroLogo, width: 300, height: 46 },
      { name: 'Seiha English Academy', logo: seihaLogo, width: 287, height: 300, badge: true },
      { name: 'Iloilo Mission Hospital', logo: iloiloMissionLogo, width: 300, height: 291, badge: true },
      { name: 'Department of Tourism', logo: dotLogo, width: 300, height: 300, badge: true },
    ]}
  >
    <Fragment slot="tagline">Our Clients</Fragment>
    <Fragment slot="subtitle">
      From healthcare and government to manufacturing and education, teams nationwide rely on Konseptu to build, run,
      and scale their systems.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </OurClients>

  <!-- Features Widget *************** -->

  <Features
    id="commitment"
    title="Our commitment to you"
    items={[
      {
        title: 'Timely Communication',
        description: 'Clear, transparent, and responsive communication to ensure alignment and success at every stage.',
        icon: 'tabler:bubble-text',
      },
      {
        title: 'Speed of Delivery',
        description: 'Rapid development and deployment without compromising quality or performance.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Performant Systems',
        description: 'Scalable, reliable, and efficient solutions that meet your present and future needs.',
        icon: 'tabler:brand-speedtest',
      },
      {
        title: 'Cost Effectiveness',
        description: 'Delivering high-quality services and systems while ensuring cost-efficiency for our clients.',
        icon: 'tabler:coin',
      },
    ]}
  >
    <Fragment slot="subtitle"> We strive to deliver the best experience to our clients. </Fragment>
  </Features>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    id="cta"
    actions={[
      {
        variant: 'primary',
        text: 'Email us',
        href: 'mailto:contact@konseptu.com',
        target: '_blank',
        icon: 'tabler:mail',
      },
      {
        variant: 'primary',
        text: 'Send SMS',
        href: 'sms:+639524778680',
        target: '_blank',
        icon: 'tabler:message',
      },
      {
        variant: 'primary',
        text: 'Live Chat',
        href: '#',
        icon: 'tabler:message-circle',
      },
    ]}
  >
    <Fragment slot="title"> Consult with us for free today </Fragment>

    <Fragment slot="subtitle">
      Schedule with us for onsite visits and presentations as long as it's within Cebu Province, or virtual calls
      instead
    </Fragment>
  </CallToAction>

  <script>
    // Live chat handler
    document.addEventListener('DOMContentLoaded', () => {
      const liveChatBtn = document.querySelector('a[href="#"]');
      if (liveChatBtn && liveChatBtn.textContent?.includes('Live Chat')) {
        liveChatBtn.addEventListener('click', (e) => {
          e.preventDefault();
          if (typeof window.Tawk_API !== 'undefined') {
            window.Tawk_API.toggle();
          }
        });
      }
    });
  </script>
</Layout>
